# FreeRADIUS configs, LDIF, and compose files must keep LF endings —
# CRLF breaks parsing inside the Linux containers.
* text=auto
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ldif text eol=lf
*.md text eol=lf
.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.claudeignore text eol=lf
freeradius/** text eol=lf
web/** text eol=lf

# Binary assets (favicons, screenshots) must not be line-ending normalized;
# these come after web/** so `binary` (= -text) wins for them.
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
