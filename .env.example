# ============================================================================
# docker-freeradius-ldap configuration
#
# Copy to .env and edit:   cp .env.example .env
# The real .env is git-ignored; never commit it.
# ============================================================================

# ----------------------------------------------------------------------------
# RADIUS clients (NAS devices)
# ----------------------------------------------------------------------------
# Host UDP ports to publish for authentication and accounting. The container
# always listens on 1812/1813 internally; change these only to expose
# different ports on the Docker host.
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# Which source IPs may talk to this RADIUS server. Use a CIDR that covers your
# NAS devices (switches, APs, VPN concentrators). 0.0.0.0/0 is for testing
# only -- restrict it in production.
RADIUS_CLIENT_IP=0.0.0.0/0

# Shared secret between the NAS devices and this server. Change it.
RADIUS_CLIENT_SECRET=testing123

# Optional: only allow members of this LDAP/AD group to authenticate.
# Leave empty to allow any user found in the directory.
# Example (AD or dev LDAP): radius-users
RADIUS_REQUIRED_GROUP=

# ----------------------------------------------------------------------------
# LDAP / Active Directory connection
# ----------------------------------------------------------------------------
# Defaults below match the bundled dev OpenLDAP container
# (docker compose --profile dev up -d).
#
# Active Directory example:
#   LDAP_SERVER=ldaps://dc01.corp.example.com:636
#   LDAP_START_TLS=no
#   LDAP_BIND_DN=CN=svc-radius,OU=Service Accounts,DC=corp,DC=example,DC=com
#   LDAP_BASE_DN=DC=corp,DC=example,DC=com

# Full LDAP URI: ldap://host:389 or ldaps://host:636
LDAP_SERVER=ldap://openldap:389

# Upgrade a plain ldap:// connection to TLS (yes/no). Do not combine with ldaps://.
LDAP_START_TLS=no

# Certificate checking for TLS connections: never | allow | try | demand
# "allow" tolerates self-signed / internal-CA certs; use "demand" with a
# trusted certificate in production.
LDAP_TLS_REQUIRE_CERT=allow

# Service account used to search the directory. Use a least-privilege,
# read-only account.
LDAP_BIND_DN=cn=admin,dc=example,dc=org
LDAP_BIND_PASSWORD=adminpassword

# Search base for everything below
LDAP_BASE_DN=dc=example,dc=org

# ----------------------------------------------------------------------------
# User lookup
# ----------------------------------------------------------------------------
# Active Directory example:
#   LDAP_USER_BASE_DN=OU=Staff,DC=corp,DC=example,DC=com
#   LDAP_USER_OBJECT_FILTER=(&(objectClass=user)(!(userAccountControl:1.2.840.113556.1.4.803:=2)))
#   LDAP_USER_NAME_ATTRIBUTE=sAMAccountName

LDAP_USER_BASE_DN=ou=people,dc=example,dc=org
LDAP_USER_OBJECT_FILTER=(objectClass=inetOrgPerson)
LDAP_USER_NAME_ATTRIBUTE=uid

# ----------------------------------------------------------------------------
# Group lookup
# ----------------------------------------------------------------------------
# Active Directory example:
#   LDAP_GROUP_BASE_DN=DC=corp,DC=example,DC=com
#   LDAP_GROUP_OBJECT_FILTER=(objectClass=group)
#   LDAP_GROUP_MEMBERSHIP_FILTER=(member=%{control:Ldap-UserDn})
#   LDAP_GROUP_MEMBERSHIP_ATTRIBUTE=memberOf

LDAP_GROUP_BASE_DN=ou=groups,dc=example,dc=org
LDAP_GROUP_OBJECT_FILTER=(objectClass=groupOfNames)
LDAP_GROUP_MEMBERSHIP_FILTER=(member=%{control:Ldap-UserDn})
LDAP_GROUP_MEMBERSHIP_ATTRIBUTE=memberOf

# ----------------------------------------------------------------------------
# Dev-only settings (used by the optional --profile dev OpenLDAP container)
# ----------------------------------------------------------------------------
DEV_LDAP_ADMIN_PASSWORD=adminpassword
